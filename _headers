# Cloudflare Pages — HTTP response headers
# Docs: https://developers.cloudflare.com/pages/configuration/headers/

# ----------------------------------------------------------------------
# Global security headers — applied to every response
# ----------------------------------------------------------------------
/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=(), interest-cohort=()
  X-Frame-Options: SAMEORIGIN
  Cross-Origin-Opener-Policy: same-origin

# ----------------------------------------------------------------------
# Long-lived assets — images / fonts / icons / PDFs
# Cache 1 year, immutable. Filenames don't carry version hashes, but
# the binary contents change rarely (and re-uploads invalidate the URL).
# ----------------------------------------------------------------------
/assets/*
  Cache-Control: public, max-age=31536000, immutable

/favicon.ico
  Cache-Control: public, max-age=2592000

# ----------------------------------------------------------------------
# Versioned scripts & styles at the site root
# The HTML references these with a `?v=YYYYMMDD<letter>` query string;
# every deploy bumps the suffix, so each version gets a fresh URL while
# old ones stay safely cached. `immutable` lets the browser skip
# revalidation entirely.
# ----------------------------------------------------------------------
/styles.css
  Cache-Control: public, max-age=31536000, immutable
/analytics.js
  Cache-Control: public, max-age=31536000, immutable
/ui.js
  Cache-Control: public, max-age=31536000, immutable
/script.js
  Cache-Control: public, max-age=31536000, immutable
/microcms-config.js
  Cache-Control: public, max-age=31536000, immutable
/microcms-extras.js
  Cache-Control: public, max-age=31536000, immutable
/sponsor-urls.js
  Cache-Control: public, max-age=31536000, immutable

# ----------------------------------------------------------------------
# Service Worker — never cache, always fetch fresh so updates roll out
# immediately. The SW itself controls cache for everything else.
# ----------------------------------------------------------------------
/sw.js
  Cache-Control: public, max-age=0, must-revalidate
  Service-Worker-Allowed: /

# ----------------------------------------------------------------------
# PWA manifest — short cache; can change between releases
# ----------------------------------------------------------------------
/manifest.json
  Cache-Control: public, max-age=3600

# ----------------------------------------------------------------------
# HTML pages — short cache, SW does the heavy lifting offline.
# 5 minutes keeps repeat-visit fast while still letting deploys go live.
# ----------------------------------------------------------------------
/*.html
  Cache-Control: public, max-age=300, must-revalidate
  X-Robots-Tag: index, follow

/
  Cache-Control: public, max-age=300, must-revalidate

# ----------------------------------------------------------------------
# 404 page — tell crawlers not to index it
# ----------------------------------------------------------------------
/404.html
  X-Robots-Tag: noindex, follow
  Cache-Control: public, max-age=300

# ----------------------------------------------------------------------
# Sitemap & robots — short cache so SEO updates propagate
# ----------------------------------------------------------------------
/sitemap.xml
  Cache-Control: public, max-age=3600
  Content-Type: application/xml; charset=utf-8

/robots.txt
  Cache-Control: public, max-age=3600
